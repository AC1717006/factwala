# ─── Local Dev SSL (corporate proxy / VPN fix) ───────────────────────────────
# Set to true ONLY for local development. NEVER use in GitHub Actions / production.
DISABLE_SSL_VERIFY=false

# ─── Instagram / Meta API ─────────────────────────────────────────────────────
# Instagram Business Account ID (from Meta Business Suite)
INSTAGRAM_BUSINESS_ID=your_instagram_business_id

# Facebook Page ID linked to the Instagram account
FACEBOOK_PAGE_ID=your_facebook_page_id

# Meta App credentials — https://developers.facebook.com
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# Long-lived User Access Token with instagram_content_publish permission
# Generate at: https://developers.facebook.com/tools/explorer/
# Expires in ~60 days — regenerate regularly
META_ACCESS_TOKEN=your_long_lived_meta_access_token

# ─── GNews API ────────────────────────────────────────────────────────────────
# Free tier: 100 req/day | Get key at: https://gnews.io
News_API=your_gnews_api_key

# ─── Groq AI API (legacy / unused by default) ────────────────────────────────
# Free tier available | Get key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key

# ─── Claude AI API (Anthropic) ───────────────────────────────────────────────
# Used to rewrite news into a 3-slide Hindi carousel post
# Get key at: https://console.anthropic.com
CLAUDE_API_KEY=your_claude_api_key

# Optional: override the Claude model (default: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# ─── ImgBB Image Hosting ──────────────────────────────────────────────────────
# Required: Instagram Graph API needs a public HTTPS image URL
# Free API key at: https://imgbb.com/api
IMGBB_API_KEY=your_imgbb_api_key
